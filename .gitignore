# ---------- .gitignore ----------

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
System Volume Information/

# IDEs (IntelliJ, Eclipse, VS Code)
.idea/
*.iml
*.ipr
*.iws
.vscode/
.vscode-test/
.nb-gradle
.factorypath
*.code-workspace
*.launch
.claude/
.settings/
.classpath
.project
.idea_modules/

# Build outputs (any depth)
build/
out/
bin/
target/
run/
run-data/
coverage/
tmp/

# Gradle caches and local config (any depth)
.gradle/
gradle-local.properties
local.properties

# Logs and temporary files
*.log
hs_err_pid*
*.tmp
*.swp
*.bak
*.bak2
*.orig
*.lock
*.cache

# Java artifacts (keep gradle wrapper jar)
*.jar
!**/gradle-wrapper.jar

# Assistants & Local Tools
.gemini/
.history/
/.cursor
.env

# Minecraft junk
crash-reports/
usercache.json
usernamecache.json
stats/
advancements/
backups/
screenshots/
logs/
!/src/**/logs/
replay_mod_recordings/
.mixin.out/
.mixin.out

# Misc dev files
*.patch
*.diff
*.ps1
*.py
*.lnk
.legacy/
.apt_generated/
.cache/

# Markdown (keep README)
*.md
!README.md

# Text files (keep license/credits)
*.txt
!LICENSE.txt
!CREDITS.txt

# Windows
NUL

# Minecraft dev folder
.minecraft/

# Others
/.archive
*.pdf
/tools
/wiki
