{
  "id": "flandre_boss",
  "name": "Flandre Scarlet",
  "_design_notes": [
    "TH06 Extra Stage boss (ecldata7 / Stage 7). Spell order: Cranberry Trap → Laevatein → Four of a Kind → Kagome Kagome → Maze of Love → Forbidden Barrage Starbow Break.",
    "Taboo「フォーオブアカインド」: TH06 uses clone familiars. This build implements logical phase emitters (no sprite) so clone-origin fire can be reproduced from the correct off-screen positions.",
    "Patchouli midboss (Extra) is not a separate arena boss here; fairy stage follows ecldata7 Timeline0 through Sub8 with a gap where Sub16 would run.",
    "Nonspells map to ECL drivers Sub32 / Sub35 / Sub38 / Sub47 / Sub49 (ins_70 fans + ins_50 radial bursts), not Remilia Sub20-style laser opens.",
    "Music: U.N. Owen was her? — track id u_n_owen_was_her. Patterns use existing PatternStep only."
  ],
"introDialog": [
  { "speaker": "BOSS", "text": "I was sooo bored down here… so I found something fun! If you break, it means I found the right spot, okay?", "delayTicks": 170 }
],

"characterDialogs": {
  "reimu": [
    { "speaker": "BOSS", "text": "You've got lots of little shiny threads… which one do I touch to make you go *pop*?", "delayTicks": 160 },
    { "speaker": "PLAYER", "text": "I'm not here to play your games.", "delayTicks": 130 },
    { "speaker": "BOSS", "text": "But breaking things is a game! If I touch the right place, something interesting always happens!", "delayTicks": 150 }
  ],
  "marisa": [
    { "speaker": "BOSS", "text": "Wow… you sparkle a lot! If I poke you, will you scatter everywhere?", "delayTicks": 160 },
    { "speaker": "PLAYER", "text": "Heh, careful, they bite back, ze.", "delayTicks": 130 },
    { "speaker": "BOSS", "text": "Bite? Heehee… then I just have to find where the bite stops!", "delayTicks": 155 }
  ],
  "sakuya": [
    { "speaker": "BOSS", "text": "Sakuya… you feel like a line stretched too tight. If I pull it just a little..", "delayTicks": 165 },
    { "speaker": "PLAYER", "text": "If you attempt that, I will stop you immediately.", "delayTicks": 120 },
    { "speaker": "BOSS", "text": "Heehee… then try. I want to see which of us breaks first.", "delayTicks": 145 }
  ],
  "sanae": [
    { "speaker": "BOSS", "text": "Hmm… you feel weird. Like you're not built the same. Where's your weak spot?", "delayTicks": 160 },
    { "speaker": "PLAYER", "text": "Whatever you're thinking, it won't work on me.", "delayTicks": 130 },
    { "speaker": "BOSS", "text": "Heehee… that just means I have to look extra carefully!", "delayTicks": 145 }
  ],
  "cirno": [
    { "speaker": "BOSS", "text": "Oh! You look easy to understand! I bet I can figure you out quickly!", "delayTicks": 165 },
    { "speaker": "PLAYER", "text": "Hey! I'm the strongest!", "delayTicks": 130 },
    { "speaker": "BOSS", "text": "Strong? That's fine! Strong things are the most fun when they suddenly stop working!", "delayTicks": 150 }
  ]
},

"victoryDialog": "Eh? It stopped already? I didn't even find the fun part yet…",
"defeatDialog": "Ah… I see it! So that's where everything ends… how pretty…",

"victoryDialogByCharacter": {
  "reimu": "Huh… I couldn't find anything interesting inside at all…",
  "marisa": "Aww… it all just faded away. That's boring…",
  "sakuya": "You kept slipping away… I couldn't catch the ending.",
  "sanae": "You were strange… but you still ended the same way.",
  "cirno": "Huh? You just stopped? That was quick!"
},

"defeatDialogByCharacter": {
  "reimu": "Oh! There it is! That's the spot!",
  "marisa": "Whoa… it all came apart like sparks!",
  "sakuya": "Even time can't hide that point forever, it seems.",
  "sanae": "So you really did have one…",
  "cirno": "I found it! I found it first!"
},
