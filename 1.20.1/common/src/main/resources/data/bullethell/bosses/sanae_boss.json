{
  "id": "sanae_boss",
  "name": "Sanae Kochiya",
  "_design_notes": [
    "Primary reference: https://touhou.fandom.com/wiki/Mountain_of_Faith:_Stage_5_Spell_Cards (TH10 Stage 5 spell cards, comments, difficulty splits).",
    "Midboss Esoterica: E/N «Gray Thaumaturgy»; H «Forgotten Ritual»; L «Secretly Inherited Art of Danmaku».",
    "Boss Wonder: E/N «Daytime Guest Stars»; H «Night with Bright Guest Stars»; L «Night with Overly Bright Guest Stars» (客星 = guest stars / comets etc.).",
    "Sea Opening: E/N «The Day the Sea Split» (Exodus Red Sea); H/L «Moses's Miracle». Wiki: lasers frame a canal for the duel; knives are aimed (not laser-bullet spam as main threat).",
    "Preparation: E/N «Star Ritual to Call the Godly Winds» (Three Kingdoms / borrowing wind); H/L «Takeminakata Invocation».",
    "Finale Miracle: E/N «God's Wind» (kamikaze typhoons); H/L «Great Miracle: Yasaka's Divine Wind».",
    "Engine shorthand: Sea Opening uses LASER_ROTATING arms=2 (bidirectional spokes = moving “canal” sectors) + AIMED KNIFE bursts; not LASER_BEAM curtains. PENTAGRAM / DENSE_RING / RAIN for star & wind spells."
  ],
  "introDialog": [
    {
      "speaker": "BOSS",
      "text": "The wind from Moriya carries my miracle. If you still stand here, face it with everything you have!",
      "delayTicks": 170
    }
  ],
  "characterDialogs": {
    "reimu": [
      { "speaker": "BOSS", "text": "Hakurei shrine maiden? Then you know faith is won in the sky, not on paper.", "delayTicks": 165 },
      { "speaker": "PLAYER", "text": "I'll settle this incident whether your god helps or not.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Good. Show me that resolve in your dodging!", "delayTicks": 150 }
    ],
    "marisa": [
      { "speaker": "BOSS", "text": "A magician from the forest? Don't expect miracles to wait politely in line.", "delayTicks": 165 },
      { "speaker": "PLAYER", "text": "Miracles, stars, whatever — I'll graze through and steal the win, ze!", "delayTicks": 135 },
      { "speaker": "BOSS", "text": "Then keep up with the wind until the last spell breaks!", "delayTicks": 155 }
    ],
    "sakuya": [
      { "speaker": "BOSS", "text": "Scarlet Devil Mansion's maid, all the way up the mountain? You must be serious.", "delayTicks": 165 },
      { "speaker": "PLAYER", "text": "Time is on my side — I'll clear your patterns all the same.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Then let the gale test whether your clocks can keep their tick.", "delayTicks": 155 }
    ],
    "sanae": [
      { "speaker": "BOSS", "text": "Another me? Fine — let's see which faith the mountain answers!", "delayTicks": 165 },
      { "speaker": "PLAYER", "text": "I'll prove I'm not just a copy!", "delayTicks": 115 },
      { "speaker": "BOSS", "text": "Words won't decide it. The danmaku will.", "delayTicks": 145 }
    ],
    "cirno": [
      { "speaker": "BOSS", "text": "A fairy climbed this high? Either brave or very lost.", "delayTicks": 160 },
      { "speaker": "PLAYER", "text": "I'm the strongest! Your wind can't blow that away!", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "We'll see if ice can anchor you when the gale hits.", "delayTicks": 150 }
    ]
  },
  "victoryDialog": "Amazing... even Kanako would call that a worthy miracle.",
  "defeatDialog": "Faith needs practice too. Come back when you're ready.",
  "victoryDialogByCharacter": {
    "reimu": "The Hakurei shine even outside your shrine. Respect.",
    "marisa": "You really did bulldoze through — just try not to blow up the shrine, ze.",
    "sakuya": "Precision and nerve — Lady Remilia would notice that composure.",
    "sanae": "So I can lose to myself... guess I need more training.",
    "cirno": "Strongest fairy after all? I'll remember that chill."
  },
  "defeatDialogByCharacter": {
    "reimu": "Your feet hesitated before your faith did.",
    "marisa": "Too greedy on the spark, not enough on the wind.",
    "sakuya": "Even perfect timing slips in a gale.",
    "sanae": "Miracles don't wait for doubt.",
    "cirno": "The strongest title needs more than bravado."
  },
