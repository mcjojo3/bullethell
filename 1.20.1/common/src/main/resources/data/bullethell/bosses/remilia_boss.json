{
  "id": "remilia_boss",
  "name": "Remilia Scarlet",
  "_design_notes": [
    "ECL mapping: wiki/remilia-th06-reconstruction.md — decompiled ecldata6_bullets.txt (e.g. G:\\thtk-bin-12\\th6). Phase _note fields name TH06 subs (Sub30–Sub45 spells, Sub19–Sub22 nonspell drivers).",
    "EoSD Stage 6 (TH6) Remilia roster: E/N = Heaven's Punishment Star of David, Nether Sign Scarlet Netherworld, Curse Vlad Tepes, Scarlet Shoot, Red Magic. H/L = Divine Punishment Young Demon Lord, Hell Sign Mountain of a Thousand Needles, Divine Art Vampire Illusion, Scarlet Meister, Scarlet Gensokyo.",
    "Projectile parity: sparse large scarlet orbs use bulletScale + forgiving hitboxScale (hit smaller than draw). True LaserPool spokes on Star of David / Young Demon Lord / Gensokyo; Scarlet Meister is MEISTER_CYCLE (shotgun + mentos trail toward player + spin bursts; uses phase bulletType + scales from JSON). Scarlet Gensokyo bounces use large scarlet orbs (not HOMING_ORB — enemy bullets do not run player homing tick).",
    "Engine: bulletScale/hitboxScale/densityScale/maxScaledArms on PatternStep; optional speed/spread/arms min-max sampling; adaptive scalingProfile/pressure throttles for readability; MEISTER_CYCLE; RAIN, NEEDLE, RING_OFFSET, BOUNCE, SCARLET / SCARLET_LARGE / SCARLET_MENTOS, LASER / LASER_ROTATING / LASER_BEAM, SPIRAL, DENSE_RING.",
    "Visual parity: scarlet orb families render as texture-backed tinted orbs with layered glow, while mentos/needles keep geometric silhouettes for lane readability.",
    "Blueprint (PatternStep): bulletLifetimeTicks — RING/SPIRAL/RING_OFFSET/DENSE_RING 200, AIMED/SPREAD/LASER_BEAM 220, RAIN 230, BOUNCE 250. LASER / LASER_ROTATING use LaserPool (warn/active/halfWidth). LASER_BEAM is a bullet fan (not LaserPool): optional laserBeamSpread rad (default ~0.04); omit warn/active. AIMED_RING omits lifetime so aim≈220 and ring≈200. ringStartAngleRad -1 on RING_OFFSET / AIMED_RING ring, 0 on RING/DENSE_RING. MEISTER_CYCLE is scripted separately."
  ],
  "_validation_matrix": [
    "EASY/NORMAL: Star of David reads as six-spoke laser web + layered orbs; Netherworld scarlet rain + fewer large wall orbs; Vlad lanes clear; Scarlet Shoot spear columns + scarlet; Red Magic layered (not uniform flood).",
    "HARD/LUNATIC: Young Demon Lord denser spokes + spiral; Mountain needle lattice; Vampire Illusion lasers + blood-orb pressure; Meister cycles aim→spin→rest with CIRCLE movement; Gensokyo finale mixed geometry.",
    "Network: enemy BulletPool STRIDE=9 sync (delta + full + player pools); co-op bullets/lasers unchanged protocol aside from float count.",
    "Regression: graze/hit use bullet radius × hitScale; large orbs remain fair vs sprite size."
  ],
  "introDialog": [
    { "speaker": "BOSS", "text": "Welcome to my castle at the end of the night. I am Remilia Scarlet - show me your fate.", "delayTicks": 170 }
  ],
  "characterDialogs": {
    "reimu": [
      { "speaker": "BOSS", "text": "Hakurei shrine maiden, your fate brought you to my throne. Entertain me.", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "Fine. I'll end this night and drag you into daylight.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Daylight? How quaint. Stay until I decide the moon's color.", "delayTicks": 160 }
    ],
    "marisa": [
      { "speaker": "BOSS", "text": "Back again, little thief? Then steal your victory if you can.", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "Heh, I was planning to. Add your title to the loot list, ze.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Bold words, prove your worth in scarlet wind before you count your spoils.", "delayTicks": 165 }
    ],
    "sakuya": [
      { "speaker": "BOSS", "text": "A maid who turns her blades toward her mistress? Fascinating.", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "Tonight I follow my own judgment.", "delayTicks": 120 },
      { "speaker": "BOSS", "text": "Then let judgment be written in the rhythm of your blood.", "delayTicks": 155 }
    ],
    "sanae": [
      { "speaker": "BOSS", "text": "A living god's priestess challenges a devil? Delightful irony.", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "Then let's see whether destiny favors gods or devils.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Spoken well, now bleed poetry into the sky and show me.", "delayTicks": 160 }
    ],
    "cirno": [
      { "speaker": "BOSS", "text": "A fairy at my doorstep. Are you lost, or merely fearless?", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "Neither! I'm here to beat the final boss!", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Final? Adorable. The night rewards those who outlast fairy tales.", "delayTicks": 165 }
    ]
  },
  "victoryDialog": "How unexpected... perhaps fate has teeth after all.",
  "defeatDialog": "Your fate was sealed the moment you stepped into my hall.",
  "victoryDialogByCharacter": {
    "reimu": "So this is the shrine maiden who defies destiny. Splendid.",
    "marisa": "You really did steal the night from me, magician.",
    "sakuya": "A blade turned inward can still cut deep. Well done.",
    "sanae": "Divine conviction overcame vampiric pride. Intriguing.",
    "cirno": "A fairy who reaches this throne... truly extraordinary."
  },
  "defeatDialogByCharacter": {
    "reimu": "Even exorcists stumble in scarlet darkness.",
    "marisa": "Greed clouded your aim, little magician.",
    "sakuya": "Loyalty wavered, and so did your hand.",
    "sanae": "Faith falters when blood moonlight rises.",
    "cirno": "Bravery alone cannot rule the night."
  },
