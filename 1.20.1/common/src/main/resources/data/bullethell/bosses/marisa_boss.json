{
  "id": "marisa_boss",
  "name": "Marisa Kirisame",
  "_design_notes": [
    "Inspired by Marisa's Imperishable Night (TH8) Stage 4B-style fight — feel-based, not a frame-perfect port.",
    "Phase flow: opening aimed pressure -> Magic Sign \"Milky Way\" -> nonspell -> Starlight Typhoon-style (aimed + spark beams + optional laser wheel) -> late nonspell -> Love Sign \"Master Spark\" -> Final Sign \"Double Spark\".",
    "Patterns favor AIMED, LASER_BEAM, and AIMED_RING (fan + ring) toward the nearest living player (co-op).",
    "LASER_ROTATING: bidirectional beams, one burst in the Typhoon phase for a laser-wheel moment.",
    "LASER: wide aimed beam (Master Spark). GOLD / STAR / RICE / SPARK / ORB as usual."
  ],
  "characterDialogs": {
    "reimu": [
      {
        "speaker": "BOSS",
        "text": "Yo, Reimu! Late as usual. I already 'borrowed' all the good loot from this place!",
        "delayTicks": 160
      },
      {
        "speaker": "PLAYER",
        "text": "Marisa... Give it back before the owner files a complaint that I'll have to deal with.",
        "delayTicks": 140
      },
      {
        "speaker": "BOSS",
        "text": "No way, finders keepers, ze! Besides, I need a tough test dummy for my new star magic.",
        "delayTicks": 180
      },
      {
        "speaker": "PLAYER",
        "text": "I really don't have time for your games today. Get out of my way or get exterminated.",
        "delayTicks": 120
      },
      {
        "speaker": "BOSS",
        "text": "That's the spirit! Let's see if your dodging is as sharp as your tongue! Here I come!",
        "delayTicks": 160
      }
    ],
    "marisa": [
      {
        "speaker": "BOSS",
        "text": "Hey, wait a second! You're wearing my clothes! And my hat! What gives, ze?!",
        "delayTicks": 160
      },
      {
        "speaker": "PLAYER",
        "text": "I could say the exact same thing to you, faker! Is this some kind of tanuki trick?",
        "delayTicks": 140
      },
      {
        "speaker": "BOSS",
        "text": "A fake?! I'm the one and only ordinary magician! I'll prove it with my firepower!",
        "delayTicks": 180
      },
      {
        "speaker": "PLAYER",
        "text": "Bring it on! I'll blast you so hard you'll forget my name! I mean, your name!",
        "delayTicks": 120
      },
      {
        "speaker": "BOSS",
        "text": "Whoever survives gets exclusive rights to the Master Spark! Let's go!",
        "delayTicks": 160
      }
    ],
    "sakuya": [
      {
        "speaker": "BOSS",
        "text": "Oh hey, Sakuya! Perfect timing. Tell Patchy I'll return those books... eventually.",
        "delayTicks": 160
      },
      {
        "speaker": "PLAYER",
        "text": "Lady Patchouli specifically sent me to retrieve them today, Marisa. With force, if necessary.",
        "delayTicks": 140
      },
      {
        "speaker": "BOSS",
        "text": "Force? Sounds like fun! But you'll have to catch me first!",
        "delayTicks": 180
      },
      {
        "speaker": "PLAYER",
        "text": "Time is literally on my side. I will clean up this mess and take back the Mansion's property.",
        "delayTicks": 120
      }
    ],
    "sanae": [
      {
        "speaker": "BOSS",
        "text": "Well, well, if it isn't the Moriya Shrine's poster girl. Out collecting faith today?",
        "delayTicks": 160
      },
      {
        "speaker": "PLAYER",
        "text": "Exactly! And defeating a notorious thief like you will surely boost our shrine's reputation!",
        "delayTicks": 140
      },
      {
        "speaker": "BOSS",
        "text": "Notorious thief? I'm just an ordinary magician! You can't beat me with miracles alone, ze.",
        "delayTicks": 180
      },
      {
        "speaker": "PLAYER",
        "text": "Common sense doesn't apply in Gensokyo! Prepare to face the power of a living god!",
        "delayTicks": 120
      },
      {
        "speaker": "BOSS",
        "text": "Ha! I don't need gods, just my Mini-Hakkero! Eat my stardust!",
        "delayTicks": 160
      }
    ]
  },
