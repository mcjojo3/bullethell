{
  "id": "sakuya_boss",
  "name": "Sakuya Izayoi",
  "_design_notes": [
    "TH6 Stage 5 strict split: E/N uses Clock Corpse -> Luna Clock -> Manipulating Doll; H/L uses Jack the Ludo Bile -> The World -> Killing Doll.",
    "Alternating nonspells are shared while spellcards are difficulty-gated.",
    "AIMED/SPREAD use bulletType KNIFE (knife.png); RING/SPIRAL/BOUNCE/RING_OFFSET knife walls use KUNAI (kunai.png, slightly smaller sprite, same hitbox).",
    "Balance pass: minCooldown + maxScaledArms on high-arm steps; spellDurationTicks ladder for E/N and H/L spell timers; see wiki/sakuya-th06-reconstruction.md.",
    "Blueprint (PatternStep): bulletLifetimeTicks — RING/SPIRAL/RING_OFFSET 200, AIMED/SPREAD 220, BOUNCE 250. ringStartAngleRad -1 on RING_OFFSET (random), 0 on RING. bulletAngularVelocity/spawn offsets unused."
  ],
  "introDialog": [
    {
      "speaker": "BOSS",
      "text": "Trespassing in the Scarlet Devil Mansion uninvited? I shall have to stop you here.",
      "delayTicks": 160
    }
  ],
  "characterDialogs": {
    "reimu": [
      { "speaker": "BOSS", "text": "Hakurei shrine maiden, your visit was not scheduled. I must escort you out.", "delayTicks": 160 },
      { "speaker": "PLAYER", "text": "You can try, but I'm finishing this incident first.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Then I shall delay your incident until dawn, if you survive that long.", "delayTicks": 155 }
    ],
    "marisa": [
      { "speaker": "BOSS", "text": "Magician, once again you enter without permission.", "delayTicks": 160 },
      { "speaker": "PLAYER", "text": "Permission slips are boring. Danmaku is faster.", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Speed without discipline is merely noise. I will silence it.", "delayTicks": 155 }
    ],
    "sakuya": [
      { "speaker": "BOSS", "text": "An imitation maid? Very well. Let's see how your time compares to mine.", "delayTicks": 170 },
      { "speaker": "PLAYER", "text": "I only need one opening.", "delayTicks": 120 },
      { "speaker": "BOSS", "text": "One opening is all I require as well.", "delayTicks": 140 }
    ],
    "sanae": [
      { "speaker": "BOSS", "text": "A guest from the mountain? The mansion is closed tonight.", "delayTicks": 160 },
      { "speaker": "PLAYER", "text": "Then I'll open it by force.", "delayTicks": 120 },
      { "speaker": "BOSS", "text": "Foolish. The door you seek is a wall of knives.", "delayTicks": 150 }
    ],
    "cirno": [
      { "speaker": "BOSS", "text": "A fairy reached this far? Unexpected. Do not waste my time.", "delayTicks": 160 },
      { "speaker": "PLAYER", "text": "I'm not wasting it, I'm freezing it!", "delayTicks": 130 },
      { "speaker": "BOSS", "text": "Time is mine to stop, not yours to freeze. Enough prattle.", "delayTicks": 155 }
    ]
  },
  "victoryDialog": "You have potential. Return after sharpening your technique.",
  "defeatDialog": "Order restored. Please see yourself out.",
  "victoryDialogByCharacter": {
    "reimu": "A precise victory. Lady Remilia will remember this.",
    "marisa": "As troublesome as ever, magician.",
    "sakuya": "So this is my other self's answer... impressive.",
    "sanae": "Your resolve is admirable. Your manners need work.",
    "cirno": "A fairy with this much force... noted."
  },
  "defeatDialogByCharacter": {
    "reimu": "Your rhythm broke. I only followed the gap.",
    "marisa": "Recklessness without timing is just noise.",
    "sakuya": "Your timing lagged behind mine.",
    "sanae": "Faith did not save you from precision.",
    "cirno": "Strength without control melts quickly."
  },
