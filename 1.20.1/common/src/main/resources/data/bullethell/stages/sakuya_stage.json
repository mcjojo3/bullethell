{
  "id": "sakuya_stage",
  "title": "Clock Tower Hallways",
  "_design_notes": [
    "TH06 Stage 5–inspired pre-boss flow (see wiki/sakuya-th06-reconstruction.md): side lanes, crossing corners, midboss-homage anchor, mirrored squads, pre-boss climax.",
    "Stage fairies use default enemy bullet types; Sakuya's silver knives / daggers are boss JSON only (KNIFE vs KUNAI).",
    "Fairy shots per burst scale with difficulty (EnemyType bulletCount × DifficultyConfig.densityMult; atkInterval compresses on higher diff). Opening uses more BLUE_FAIRY than RED for lighter Easy/Normal reads.",
    "spawnTick gaps ~135–260t (~6.7–13s) so waves do not stack before the prior section is cleared.",
    "WaveDefinition: optional minDifficulty / maxDifficulty (EASY…LUNATIC, same as boss phases) skip a wave on other ranks. All waves here are rank-agnostic; add gates when matching per-difficulty ECL spawns."
  ],
  "stageMusic": "the_maid_and_the_pocket_watch_of_blood",
  "bossId": "sakuya_boss",
  "nextStageId": "remilia_stage",
  "rules": {
    "itemDropEveryNthKill": 1,
    "dropCyclePattern": "POWER,POINT,POWER,POINT,POWER,POINT,POWER,POINT",
    "largeEnemyDropCyclePattern": "POWER,POINT,POWER,FULL_POWER,POINT,POWER",
    "bombDropChance": 0.0,
    "pocFraction": 0.20,
    "pocAutoCollect": true,
    "itemAttractionSpeed": 8.0,
    "deathPowerLoss": 32,
    "grazeScoringEnabled": true,
    "grazeScoreMultiplier": 1.0,
    "pointItemMaxValue": 100,
    "pointItemMinValue": 50,
    "cherrySystemEnabled": false,
    "versusKillSendsBullets": false,
    "onKillDeathBurstCount": 0
  },
